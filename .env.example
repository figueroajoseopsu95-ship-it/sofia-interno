# ============================================
# SOFIA — Production Environment Variables
# ============================================
# Copiar este archivo a .env y completar los valores
# cp .env.production.example .env
# ============================================

# --- Public URL (sin trailing slash) ---
PUBLIC_URL=http://srv910634.hstgr.cloud

# --- PostgreSQL ---
POSTGRES_USER=sofia_user
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_SEGURO_AQUI
POSTGRES_DB=sofia_db

# --- Redis ---
REDIS_PASSWORD=CAMBIAR_REDIS_PASSWORD_AQUI

# --- Auth / JWT ---
JWT_SECRET=CAMBIAR_JWT_SECRET_LARGO_Y_ALEATORIO
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- Internal API Key (backend <-> n8n) ---
INTERNAL_API_KEY=CAMBIAR_INTERNAL_KEY_AQUI

# --- n8n Auth ---
N8N_AUTH_USER=admin
N8N_AUTH_PASSWORD=CAMBIAR_N8N_PASSWORD_AQUI

# --- AI / LLM API Keys ---
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# --- Embeddings ---
EMBEDDING_MODEL=text-embedding-3-small
