# ============================================
# SOFIA Monorepo - Root .gitignore
# ============================================

# Dependencies (each subproject also has its own .gitignore)
node_modules/

# Environment files — NEVER commit secrets
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.sublime-workspace

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
.next/
out/

# Coverage
coverage/
.nyc_output/

# Misc
*.pem
*.tsbuildinfo
