    {
      "parameters": {
        "agent": "conversationalAgent",
        "promptType": "define",
        "text": "={{ $('Extraer Contexto').item.json.message }}",
        "options": {
          "systemMessage": "Eres el sistema de clasificación de SOFIA para Banesco Banco Universal. Clasifica el mensaje del empleado en EXACTAMENTE uno de estos dominios:\n\n- \"psd\": Productos y Servicios Digitales (banca digital, apps, transferencias, pagos online, tarjetas digitales, billeteras digitales)\n- \"pasivos\": Pasivos (cuentas de ahorro, cuentas corrientes, depósitos a plazo, certificados, tasas de interés)\n- \"atc\": Atención al Cliente (reclamos, quejas, procesos de atención, soporte, canales de servicio, SLAs)\n- \"finanzas\": Finanzas (pagos internos, tesorería, contabilidad, reportes financieros, administración)\n- \"comercial\": Comercial (banca empresarial, créditos comerciales, clientes corporativos, Banca de Empresas)\n- \"legal\": Legal y Compliance (SUDEBAN, BCV, AML, KYC, OFAC, normativas, prevención de lavado)\n- \"escalation\": Escalamiento (el usuario está muy frustrado, el problema es muy complejo o urgente, requiere supervisor humano)\n- \"general\": General (saludos, conversación casual, preguntas no bancarias)\n\nResponde ÚNICAMENTE con este JSON sin texto adicional:\n{\"domain\": \"<dominio>\", \"confidence\": <0.0-1.0>, \"reason\": \"<breve razón en español>\"}",
          "maxIterations": 1
        }
      },
      "id": "router-agent-001",
      "name": "Clasificador SOFIA",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [700, 300]
    },
    {
      "parameters": {
        "jsCode": "const agentOutput = $input.first().json;\n\nlet outputText = '';\nif (agentOutput.output) {\n  outputText = agentOutput.output;\n} else if (agentOutput.text) {\n  outputText = agentOutput.text;\n} else {\n  outputText = JSON.stringify(agentOutput);\n}\n\nlet domain = 'general';\nlet confidence = 0.5;\nlet reason = 'No se pudo clasificar, usando dominio por defecto';\n\ntry {\n  const jsonMatch = outputText.match(/\\{[\\s\\S]*?\\}/);\n  if (jsonMatch) {\n    const parsed = JSON.parse(jsonMatch[0]);\n    domain = parsed.domain || 'general';\n    confidence = parsed.confidence || 0.5;\n    reason = parsed.reason || '';\n  } else {\n    const directParsed = JSON.parse(outputText);\n    domain = directParsed.domain || 'general';\n    confidence = directParsed.confidence || 0.5;\n    reason = directParsed.reason || '';\n  }\n} catch (e) {\n  domain = 'general';\n  confidence = 0.3;\n  reason = 'Error al parsear clasificación: ' + e.message;\n}\n\nconst validDomains = ['psd', 'pasivos', 'atc', 'finanzas', 'comercial', 'legal', 'escalation', 'general'];\nif (!validDomains.includes(domain)) {\n  domain = 'general';\n}\n\nconst ctx = $('Extraer Contexto').item.json;\n\nreturn [\n  {\n    json: {\n      domain: domain,\n      confidence: confidence,\n      reason: reason,\n      conversationId: ctx.conversationId,\n      userId: ctx.userId,\n      message: ctx.message,\n      channel: ctx.channel,\n      historyText: ctx.historyText,\n      historyJson: ctx.historyJson\n    }\n  }\n];"
      },
