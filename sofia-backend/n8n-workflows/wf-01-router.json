    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nlet response = '';\nlet agentName = 'RouterAgent';\nlet sourcesCited = null;\nlet tokenCount = 0;\nlet modelUsed = '';\nlet costUsd = 0;\n\nif (input.response) {\n  response = input.response;\n  agentName = input.agentName || 'SpecialistAgent';\n  sourcesCited = input.sourcesCited !== undefined ? input.sourcesCited : null;\n  tokenCount = input.tokenCount || Math.ceil(response.length / 3);\n  modelUsed = input.modelUsed || '';\n  costUsd = input.costUsd || 0;\n} else if (input.error) {\n  response = 'Lo siento, ocurrió un error procesando tu solicitud. Por favor intenta de nuevo o contacta a soporte.';\n  agentName = 'RouterAgent';\n  tokenCount = Math.ceil(response.length / 3);\n} else {\n  response = 'Lo siento, no pude procesar tu solicitud en este momento. Por favor intenta de nuevo.';\n  agentName = 'RouterAgent';\n  tokenCount = Math.ceil(response.length / 3);\n}\n\nreturn [\n  {\n    json: {\n      response: response,\n      agentName: agentName,\n      sourcesCited: sourcesCited,\n      tokenCount: tokenCount,\n      modelUsed: modelUsed,\n      costUsd: costUsd,\n      latencyMs: 0\n    }\n  }\n];"
      },
